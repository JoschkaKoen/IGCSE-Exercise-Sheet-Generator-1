# Copy to `.env` and fill in values. Keep this file to SECRETS ONLY.
#
# Non-secret options (AI_PROVIDER, DISABLE_LOGIN, model names, etc.) live in
# `default.env` in the repo — edit that file (and commit) to change defaults
# for everyone, or set variables in your shell / Docker UI for one machine.

GOOGLE_API_KEY=
XAI_API_KEY=
DASHSCOPE_API_KEY=

