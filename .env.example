# Local secrets and overrides (copy to `.env` — never commit `.env`)
#
# Shared defaults live in `default.env` (committed). This file only needs
# keys and anything you want to override.

# Required for natural language / MCQ (depending on AI_PROVIDER):
GOOGLE_API_KEY=
# XAI_API_KEY=

# Optional Scaleway / other tooling (if you use them):
# SCW_SECRET_KEY=
# SCW_DEFAULT_PROJECT_ID=

# Examples of overrides (also settable in default.env for non-secrets):
# AI_PROVIDER=xai
# DISABLE_LOGIN=false
# ACCESS_CODE=your-code
# APP_SECRET_KEY=long-random-string
