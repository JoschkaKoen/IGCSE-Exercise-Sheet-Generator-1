# Virtual environment (also match symlinked `.venv`)
.venv
.venv/
venv/
env/

# Secrets and local config — NEVER commit API-KEYS-AND-MODELS.md (it contains real keys)
.env
.env.*
!.env.example
api-keys.env
API-KEYS-AND-MODELS.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Generated output — keep xscore/exercise runs ignored; track warmed eXam bank
# (offline ``warm_bank`` output) so practice mode works on deploy without re-indexing.
output/*
!output/eXam/
output/eXam/*
!output/eXam/bank/
!output/eXam/bank/**

# Local test assets (scans, rosters)
Space Physics Unit Test/

# Runtime logs
logs/

# OS / editor
.DS_Store
.idea/
.vscode/
.claude/

# Office/LibreOffice lock files
~$*

# pytest cache
.pytest_cache/

# Generated test image outputs
scripts/scheme_graphics_test/pymupdf/
scripts/scheme_graphics_test/qwen3.6-plus/
scripts/scheme_graphics_test/gemini-3.5-flash/

# LaTeX dry-run artifacts from bug verification (.tex/.aux/.log/.pdf sidecars)
bug_verification/*_marker_dryrun.*
