# App defaults — safe to commit. Secrets (API keys) go in .env (gitignored).
#
# Model settings accept an optional thinking-effort suffix after a comma:
#   MODEL_VAR=gemini-2.5-flash, low
# Accepted effort values: off | low | high  (omit = provider default)
#
# Available models:
#   Google Gemini  (GEMINI_API_KEY)
#     gemini-2.5-flash            — fast, good quality      [thinking: off/low/high]
#     gemini-2.5-flash-lite       — cheapest / fastest      [thinking: off/low/high]
#     gemini-2.5-pro              — best stable quality     [thinking: always on]
#     gemini-3-flash-preview      — frontier quality        [thinking: always on]
#     gemini-3.1-pro-preview      — best quality (preview)  [thinking: always on]
#     gemini-3.1-flash-lite-preview — cheapest Gemini 3     [thinking: always on]
#
#   xAI Grok  (XAI_API_KEY)
#     grok-4                      — flagship
#     grok-4-1-fast-non-reasoning — fast, low cost
#
#   Alibaba Qwen  (DASHSCOPE_API_KEY)
#     qwen3.6-plus       — balanced quality/speed          [thinking: off/high]
#     qwen3.5-plus       — fast                            [thinking: off/high]
#     qwen3.5-flash      — cheapest / fastest              [thinking: off/high]
#     qwen3-max          — best quality                    [thinking: off/high]
#     qwen3-vl-flash     — vision-language, fast           [thinking: off/high]
#     qwen3.5-flash      — cheapest / fastest (Qwen3.5)    [thinking: off/high]


# ══════════════════════════════════════════════════════════════════════════════
# eXercise  —  Library + web UI
# ══════════════════════════════════════════════════════════════════════════════

# Fallback model for all eXercise AI calls (overridden by per-call vars below).
AI_DEFAULT_MODEL=gemini-3-flash-preview

# Model for the fast pre-validation step before NL processing (cheap, thinking off).
NL_SKIP_PRECHECK=false
AI_PRECHECK_MODEL=gemini-3.1-flash-lite-preview, off

# Model for natural-language query interpretation.
NL_MODEL=gemini-3.1-flash-lite-preview, low

# Model for MCQ explanation generation.
MCQ_MODEL=gemini-2.5-pro, high 

# Model for exercise difficulty ranking.
# gemini-3.1-pro-preview  — best quality (preview)
# gemini-2.5-pro          — reliable production workhorse
# gemini-3-flash-preview  — fast, good for large batches
RANKING_MODEL=gemini-2.5-pro, high
RANKING_SKIP=false

# Save intermediate debug files (.tex sources, ranking images).
SAVE_TEX=true

# ── Login ─────────────────────────────────────────────────────────────────────
# true = open access; false = require the ACCESS_CODE below
DISABLE_LOGIN=false
ACCESS_CODE=NBFLS

# Optional: fix the session signing key so sessions survive server restarts.
# APP_SECRET_KEY=


# ══════════════════════════════════════════════════════════════════════════════
# xScore  —  Exam scan pipeline (xScore.py, steps 1–17 split mode / 1–15 legacy)
# ══════════════════════════════════════════════════════════════════════════════

# ── Global API retry ──────────────────────────────────────────────────────────
MAX_RETRIES=0
RETRY_BACKOFF_S=1

# ── Provider defaults (used by multiple AI steps) ─────────────────────────────
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_OUTPUT_TOKENS=64000
KIMI_MAX_TOKENS=64000

# Step 1 — Parse grading instructions (NL → JSON)
INTERPRET_PROMPT_MODEL=gemini-3.1-flash-lite-preview, off

# Step 3 — Read student list (.xlsx / .csv / .pdf)
READ_STUDENT_LIST_MODEL=gemini-3.1-flash-lite-preview, off

# Step 5 — Detect blank pages
BLANK_DETECTION_DPI=72

# Step 6 — Autorotate
SCAN_USE_TESSERACT_ROTATION=false
# Tesseract OSD rotation-analysis DPI — only active when SCAN_USE_TESSERACT_ROTATION=true.
ROTATION_ANALYSIS_DPI=150

# Step 7 — Deskew + all coordinate-dependent geometry
# All pixel coordinates in JSON sidecars share this DPI — change as a unit.
PIPELINE_DEFAULT_DPI=300
# Format of pages embedded in cleaned_scan.pdf: jpeg (fast/lossy) or png (lossless).
CLEANED_SCAN_EMBED_FORMAT=jpeg
CLEANED_SCAN_JPEG_QUALITY=95

# Step 8 — Exam geometry: cover-page detection + name recognition
COVER_PAGE_DETECTION_MODEL=gemini-3.1-flash-lite-preview, off
COVER_PAGE_DETECTION_DPI=150
# Informational text-based check of the empty exam PDF page 1 (no vision; does not affect behaviour).
EMPTY_EXAM_COVER_MODEL=gemini-3.1-flash-lite-preview, off

NAME_DETECTION_MODEL=qwen3.6-plus, off
NAME_RECOGNITION_DPI=300
NAME_WORKERS=34
NAME_JPEG_QUALITY=95
# Step 8 — Page order / content validation (LLM compares OCR text of scan pages to empty exam).
PAGE_ORDER_CHECK_MODEL=gemini-3.1-flash-lite-preview, off
# Step 8 — Blank page detection: identify blank exam pages + handwriting check on student scans.
BLANK_PAGE_DETECTION_MODEL=gemini-2.5-flash-lite, off


# Step 9 — Detect exam layout (split mode; skipped when READ_EXAM_PDF_SPLIT=0)
DETECT_LAYOUT_MODEL=gemini-3.1-flash-lite-preview, off

# Step 10 — Parse exam PDF → question hierarchy (Gemini or Qwen)
READ_EXAM_PDF_MODEL=gemini-3-flash-preview, low

# Step 12 — Parse mark scheme → correct answers + criteria (Gemini or Qwen)
READ_MARK_SCHEME_MODEL=gemini-3-flash-preview, low

# Step 12 — Dedicated graphics detection pass (diagrams, graphs, images in mark scheme)
DETECT_SCHEME_GRAPHICS_MODEL=qwen3-vl-plus, off
# Step 12 — DPI for cropping mark scheme graphics to PNG
MARK_SCHEME_GRAPHICS_DPI=300
# Step 12 — Fractional margin added on all sides of detected bbox (0.0 = no margin)
SCHEME_GRAPHICS_MARGIN=0.01

# Steps 10–15 — AI output format: yaml (default, block scalars), json (schema-enforced), xml (original baseline)
AI_OUTPUT_FORMAT=yaml

# Step 15 — AI marking (step 13 in legacy mode)
# MARKING_DPI can be lower than PIPELINE_DEFAULT_DPI — 150 DPI is
# sufficient for handwriting and saves API upload time.
MARKING_MODEL=qwen3.6-plus, off
MARKING_DPI=300
MARKING_JPEG_QUALITY=100
# Parallel workers for AI marking and xelatex compilation.
MARKING_WORKERS=100
# Rate-limit delays (seconds). Keep at 0.0; raise if the provider returns 429s.
GRADE_QUESTION_DELAY_S=0.0
PAGE_API_DELAY_S=0.0


# ══════════════════════════════════════════════════════════════════════════════
# API cost parameters (RMB per 1 million tokens)
# ══════════════════════════════════════════════════════════════════════════════
# Fill in actual prices; leave 0.0 to skip cost estimation for that model.
# Cost is reported in 16_timing.json / 16_timing.md at the end of each run.
#
# Naming convention: replace dots and hyphens in the model name with underscores,
# uppercase, prefix COST_, suffix _INPUT or _OUTPUT.
#   e.g.  gemini-2.5-flash  →  COST_GEMINI_2_5_FLASH_INPUT / _OUTPUT

# ── Google Gemini ─────────────────────────────────────────────────────────────
# gemini-2.5-flash
COST_GEMINI_2_5_FLASH_INPUT=0.0
COST_GEMINI_2_5_FLASH_OUTPUT=0.0

# gemini-2.5-flash-lite  (BLANK_PAGE_DETECTION_MODEL default)
COST_GEMINI_2_5_FLASH_LITE_INPUT=0.68
COST_GEMINI_2_5_FLASH_LITE_OUTPUT=2.73

# gemini-2.5-pro  (MCQ_MODEL, RANKING_MODEL defaults)
COST_GEMINI_2_5_PRO_INPUT=8.54
COST_GEMINI_2_5_PRO_OUTPUT=68.30

# gemini-3-flash-preview  (READ_EXAM_PDF_MODEL, READ_MARK_SCHEME_MODEL defaults)
COST_GEMINI_3_FLASH_PREVIEW_INPUT=3.42
COST_GEMINI_3_FLASH_PREVIEW_OUTPUT=20.49

# gemini-3.1-pro-preview
COST_GEMINI_3_1_PRO_PREVIEW_INPUT=0.0
COST_GEMINI_3_1_PRO_PREVIEW_OUTPUT=0.0

# gemini-3.1-flash-lite-preview  (INTERPRET_PROMPT_MODEL, READ_STUDENT_LIST_MODEL,
#   COVER_PAGE_DETECTION_MODEL, EMPTY_EXAM_COVER_MODEL, PAGE_ORDER_CHECK_MODEL,
#   DETECT_LAYOUT_MODEL, NL_MODEL, AI_PRECHECK_MODEL defaults)
COST_GEMINI_3_1_FLASH_LITE_PREVIEW_INPUT=1.71
COST_GEMINI_3_1_FLASH_LITE_PREVIEW_OUTPUT=10.25

# ── Alibaba Qwen ──────────────────────────────────────────────────────────────
# qwen3.6-plus  (MARKING_MODEL, NAME_DETECTION_MODEL defaults)
COST_QWEN3_6_PLUS_INPUT=2.0
COST_QWEN3_6_PLUS_OUTPUT=12.0

# qwen3.5-plus
COST_QWEN3_5_PLUS_INPUT=0.0
COST_QWEN3_5_PLUS_OUTPUT=0.0

# qwen3.5-flash
COST_QWEN3_5_FLASH_INPUT=0.0
COST_QWEN3_5_FLASH_OUTPUT=0.0

# qwen3-max
COST_QWEN3_MAX_INPUT=0.0
COST_QWEN3_MAX_OUTPUT=0.0

# qwen3-vl-flash
COST_QWEN3_VL_FLASH_INPUT=0.0
COST_QWEN3_VL_FLASH_OUTPUT=0.0

# qwen3-vl-plus  (DETECT_SCHEME_GRAPHICS_MODEL default)
COST_QWEN3_VL_PLUS_INPUT=1.0
COST_QWEN3_VL_PLUS_OUTPUT=10.0

# ── xAI Grok ──────────────────────────────────────────────────────────────────
# grok-4
COST_GROK_4_INPUT=0.0
COST_GROK_4_OUTPUT=0.0

# grok-4-1-fast-non-reasoning
COST_GROK_4_1_FAST_NON_REASONING_INPUT=0.0
COST_GROK_4_1_FAST_NON_REASONING_OUTPUT=0.0
