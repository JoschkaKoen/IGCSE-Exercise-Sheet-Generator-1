# Committed defaults (safe to version-control). Put API keys and personal
# overrides in `.env` next to this file (gitignored). See `.env.example`.

# LLM: gemini (default) or xai
AI_PROVIDER=gemini

# Web app login gate — default off so local/Docker work without a code
DISABLE_LOGIN=true

# Optional (uncomment in `.env` if you need them):
# NL_SKIP_PRECHECK=1
# AI_MODEL=
# AI_MCQ_MODEL=
# AI_PRECHECK_MODEL=
# ACCESS_CODE=NBFLS
# APP_SECRET_KEY=
# ASK_LOGIN=0
