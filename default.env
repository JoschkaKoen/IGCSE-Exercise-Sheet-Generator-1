# App defaults — safe to commit. Secrets (API keys) go in .env (gitignored).
#
# ── Model line format ────────────────────────────────────────────────────────
#   <env_var>=<model>[, <thinking_tokens>][, <max_output_tokens>]
#
#   Both budgets are integers. Omit either to use the code fallback.
#   Legacy `off` / `low` / `high` strings still parse for back-compat
#   (mapped to 0 / 1024 / 8192).
#



# ── Recommended thinking_tokens ──────────────────────────────────────────────
#   Gemini (native PDF / generate_content_stream): any non-negative integer.
#       0          thinking off
#       1024       light reasoning  (matches old "low")
#       4096       moderate
#       8192       deep             (matches old "high")
#       16384+     very deep — Gemini 3 / 3.1 only
#   Gemini (OpenAI-compat / chat.completions): bucketed to none/low/high
#       — 0 → none, 1-1024 → low, 1025+ → high.
#   Qwen: 0 disables thinking (non-streaming, JSON-friendly). Any positive
#       integer enables thinking (forces streaming) AND becomes the
#       thinking_budget passed to Dashscope.
#   Kimi K2: binary on/off — 0/unset disables thinking, any positive value
#       enables it via extra_body={"thinking": {"type": "enabled"}}.
#       Non-streaming. Older moonshot-v1-* ids ignore the field.
#   Grok: ignored.
#
# ── Recommended max_output_tokens ────────────────────────────────────────────
#   16-256        single-field classification (yes/no, name extraction)
#   1024-4096     small JSON config / decision output
#   8192-16384    medium generation (MCQ explanations, page-order check)
#   32768-64000   long-form (mark scheme parsing, scaffold, marking)
#
# ── Available models ─────────────────────────────────────────────────────────
#   Google Gemini  (GEMINI_API_KEY)
#     gemini-2.5-flash              — fast, good quality      [thinking: off/low/high]
#     gemini-2.5-flash-lite         — cheapest / fastest      [thinking: off/low/high]
#     gemini-2.5-pro                — best stable quality     [thinking: always on]
#     gemini-3.5-flash        — frontier quality        [thinking: always on]
#     gemini-3.1-pro-preview        — best quality (preview)  [thinking: always on]
#     gemini-3.1-flash-lite — cheapest Gemini 3       [thinking: always on]
#
#   xAI Grok  (XAI_API_KEY)
#     grok-4                        — flagship
#     grok-4-1-fast-non-reasoning   — fast, low cost
#
#   Alibaba Qwen  (DASHSCOPE_API_KEY)
#     qwen3.6-plus                  — balanced quality/speed  [thinking: off/high]
#     qwen3.5-plus                  — fast                    [thinking: off/high]
#     qwen3.6-flash                 — better / fastest        [thinking: off/high]
#     qwen3.5-flash                 — cheapest / fastest      [thinking: off/high]
#     qwen3-max                     — best quality            [thinking: off/high]
#     qwen3-vl-flash                — vision-language, fast   [thinking: off/high]
#     qwen3-vl-plus                 — vision-language         [thinking: off/high]
#
#   Moonshot Kimi  (KIMI_API_KEY; default endpoint https://api.moonshot.cn/v1
#                   — override via KIMI_BASE_URL=https://api.moonshot.ai/v1
#                   for the international endpoint. Keys are NOT interchangeable
#                   between regions.)
#     Empty exam paper / mark scheme PDFs are uploaded to Moonshot's
#     file-extract endpoint and the extracted text is injected as a system
#     message (see kimi_pdf_text() in eXercise/ai_client.py). The four scaffold
#     PDF-parsing steps (17 extract_exam_question_numbers, 18 extract_exam_questions,
#     21 assign_scheme_questions, 22 parse_mark_scheme) auto-route through
#     this path when the model name starts with kimi or moonshot. Step 27
#     ai_marking and step 3 read_student_list are NOT wired.
#     kimi-k2.6                     — flagship (Apr 2026), 256K, multimodal  [thinking: off/on]
#     kimi-k2.5                     — multimodal, stable                     [thinking: off/on]
#     kimi-k2-turbo-preview         — Moonshot doc-default                   [thinking: off/on]
#     moonshot-v1-128k              — legacy text-only                       [thinking: n/a]


# ══════════════════════════════════════════════════════════════════════════════
# eXercise  —  Library + web UI
# ══════════════════════════════════════════════════════════════════════════════

# Fallback model for all eXercise AI calls (overridden by per-call vars below).
AI_DEFAULT_MODEL=gemini-3.5-flash

# ── Natural-language pre-validation & interpretation ─────────────────────────
# Cheap pre-check that gates expensive NL processing (thinking off).
NL_SKIP_PRECHECK=false
AI_PRECHECK_MODEL=gemini-3.1-flash-lite, 0, 1024
# Model for natural-language query interpretation.
NL_MODEL=gemini-3.1-flash-lite, 512,1024

# ── MCQ explanations & ranking ───────────────────────────────────────────────
# Model for MCQ explanation generation.
MCQ_MODEL=gemini-3.5-flash, 8192, 16384

# Model for exercise difficulty ranking.
# gemini-3.1-pro-preview  — best quality (preview)
# gemini-2.5-pro          — reliable production workhorse
# gemini-3.5-flash  — fast, good for large batches
RANKING_MODEL=gemini-3.5-flash, 8192, 32768
RANKING_SKIP=false

# ── Learn page — syllabus topic / content extraction (one-shot CLI) ──────────
# Model used by web/syllabus_topics.py (topic structure) and
# web/syllabus_content.py (per-subtopic learning-objective tables).
# Native-PDF input; structured JSON out. web/syllabus_content.py also splits
# the PDF into per-page PDFs and fires SYLLABUS_EXTRACT_WORKERS parallel
# calls — one per page — for accurate row alignment.
SYLLABUS_EXTRACT_MODEL=gemini-3.5-flash, off
SYLLABUS_EXTRACT_WORKERS=16

# ── Debug ────────────────────────────────────────────────────────────────────
# Save intermediate debug files (.tex sources, ranking images).
SAVE_TEX=true

# ── Web UI / login ───────────────────────────────────────────────────────────
# Set to false to require the ACCESS_CODE below; true (or unset) = open access.
DISABLE_LOGIN=false
ACCESS_CODE=NBFLS

# Optional: fix the session signing key so sessions survive server restarts.
# APP_SECRET_KEY=


# ══════════════════════════════════════════════════════════════════════════════
# xScore  —  Exam scan pipeline (34 pipeline steps; see xscore/shared/pipeline_steps.py)
# ══════════════════════════════════════════════════════════════════════════════

# ── Cross-cutting ────────────────────────────────────────────────────────────
# Global API retry (applied to all Gemini / Kimi calls).
ALL_MAX_RETRIES=3
ALL_RETRY_BACKOFF_S=0.05

# Per-call HTTP read timeouts for OpenAI-compatible API calls (DashScope/Qwen,
# Kimi, Grok, Gemini OpenAI-compat). Three tiers, picked at each call site via
# eXercise.ai_client.make_request_timeout(). The "read" value is the inter-chunk
# timeout for streaming responses, not the total request duration — a streamed
# call may run longer than the tier value as long as no single gap between
# chunks exceeds it. A stall raises httpx.ReadTimeout and is retried via
# retry_api_call (4 attempts) before falling through to the step's
# soft-failure path. Set ≤ 0 to disable the timeout (debug only).
# Gemini *native* calls (google.genai) use GEMINI_REQUEST_TIMEOUT_S separately.
AI_TIMEOUT_QUICK_S=60       # single-decision calls; observed max ≤ 10 s
AI_TIMEOUT_STANDARD_S=180   # vision matching / structured medium output; observed max ≤ 60 s
AI_TIMEOUT_LONG_S=360       # heavy generation / multi-page marking; observed max ≤ 300 s

# Provider defaults (used by multiple AI steps).
ALL_GEMINI_TEMPERATURE=0.0
ALL_GEMINI_MAX_OUTPUT_TOKENS=64000

# Determinism: applied automatically by ai_client.py to every chat completion /
# generate_content call when the caller hasn't passed these explicitly. Two runs
# of the same exam with identical inputs should produce identical marks.
# Leave blank to disable injection (provider defaults take over).
ALL_AI_TEMPERATURE=0.0
ALL_AI_SEED=42

# Save the images sent as visual input to the AI (JPEG/PNG/WEBP/GIF and
# PDFs rendered as visual input) into the run's output folder for human
# audit. Default off — set true to keep the per-prompt audit copies on
# disk (the prompt markdown always records mime, byte size, and sha256
# of each part regardless). Cropped mark-scheme graphic PNGs in step 20's
# mark_scheme_graphics/ are NOT controlled by this flag (step 23 reads
# them; they are always saved).
SAVE_AI_IMAGES=false


# ── Phase 1 — Setup (pipeline steps 01–03) ───────────────────────────────────

# Step 01 — parse_grading_instructions (NL → JSON)
INTERPRET_PROMPT_MODEL=qwen3.6-flash, 0, 8192

# Step 03 — read_student_list (.xlsx / .csv / .pdf)
READ_STUDENT_LIST_MODEL=qwen3.6-flash, 0, 2048


# ── Phase 2 — Scan preprocessing (pipeline steps 04–05) ──────────────────────

# Step 04 — prepare_scans (per-scan-file orientation detection + optional duplex merge).
# Per-file orientation detection is **two-stage** with usable-vote targets:
#   1. Pages are rendered at 150 DPI in spread-out (bisection-ordered) order
#      and sent to Tesseract OSD. We collect INITIAL_VOTES *usable* votes —
#      pages where Tesseract returns low confidence or errors are skipped
#      and we keep walking the candidate sequence.
#   2. If the initial votes are not unanimous (or we couldn't fill the
#      initial target), we collect ESCALATION_VOTES more usable votes from
#      different pages and majority-vote across the full set.
# Detector selection: tesseract (default, local, no API cost) | ai (vision
# LLM fallback) | auto (Tesseract if available, else AI). The AI fallback
# uses SCAN_ORIENTATION_MODEL below.
SCAN_ORIENTATION_DETECTOR=tesseract
SCAN_ORIENTATION_INITIAL_VOTES=3
SCAN_ORIENTATION_ESCALATION_VOTES=5

# AI fallback — used only when SCAN_ORIENTATION_DETECTOR=ai (or =auto and
# Tesseract is unavailable). gemini-3.5-flash measured 6/6 correct on
# s23/22 vs 5/6 for qwen3.6-flash.
SCAN_ORIENTATION_MODEL=gemini-3.5-flash, 0, 64


# Step 05 — deskew (and all later coordinate-dependent geometry).
# All pixel coordinates in JSON sidecars share this DPI — change as a unit.
PIPELINE_DEFAULT_DPI=300
# Format of pages embedded in scanned_exam_merged_and_angles_adjusted.pdf: jpeg (fast/lossy) or png (lossless).
CLEANED_SCAN_EMBED_FORMAT=jpeg
CLEANED_SCAN_JPEG_QUALITY=95
# Convergence threshold for iterative deskew (degrees). Matches the 0.01° fine-sweep step.
# Raise to 0.02 to skip the last iteration on marginal cases (slightly faster, slightly less accurate).
DESKEW_ACCURACY=0.00


# ── Phase 3 — Empty-exam analysis (pipeline steps 06–07) ─────────────────────
# These steps only need the empty exam PDF (no scan dependency); they run
# immediately after scan cleaning so problems with the empty exam surface
# early.

# Step 06 — detect_exam_layout
DETECT_LAYOUT_MODEL=qwen3.6-flash, 0, 4096

# Step 07 — cut_exam_pdf (no model — pure PDF geometry; 1×1 → "skipped",
# multi-up splits into sub-pages). Writes ``07_cut_exam_pdf/exam_input.pdf`` for
# 1×1 layouts, ``07_cut_exam_pdf/split_exam.pdf`` for multi-up.


# ── Phase 4 — Cover & geometry (pipeline steps 08–10) ────────────────────────

# Step 08 — cover_page_empty_exam
# Informational text-based check of the empty exam PDF page 1 (no vision; does not affect behaviour).
EMPTY_EXAM_COVER_MODEL=qwen3.6-flash, 0, 256

# Step 09 — cover_page_scan_first
# Vision detection of cover pages in the student scan (page 1 only — drives ``cover_page_mode``).
COVER_PAGE_DETECTION_MODEL=qwen3.6-flash, 0, 1024
COVER_PAGE_DETECTION_DPI=150

# Step 10 — exam_geometry: pages_per_student arithmetic.


# ── Phase 4.5 — Subject detection (pipeline step 11) ─────────────────────────

# Step 11 — detect_subject. Two-tier:
#   1. Filename heuristic — checks each input PDF name against
#      Subject.filename_patterns in xscore/shared/subjects.py
#      ("0478" → Computer Science today). Free, no API call.
#   2. AI fallback — native-PDF Gemini call against the first 2 pages
#      (cover + page 2) of the empty exam.
# Output gates the CODE_FORMATTING prompt section in extract_exam_question_numbers,
# extract_exam_questions, parse_mark_scheme, ai_marking, extract_student_answers.
# Subject names must match KNOWN_SUBJECTS in xscore/shared/subjects.py —
# unknown names fail fast at startup.
AVAILABLE_SUBJECTS=Computer Science,Physics,A-Level Physics,A-Level Biology,A-Level Chemistry
SUBJECT_DETECTION_MODEL=gemini-3.1-flash-lite, 0, 256


# ── Phase 5 — Per-page vision + identity + ordering (pipeline steps 12–15) ───

# Step 12 — classify_empty_exam_pages.
# One vision call per page of the EMPTY exam paper, classifying each into
# {cover page, instruction page, question page, blank page, writing space
# page} plus its printed page number. Builds the closed-vocabulary catalog
# that step 13 matches scan pages against, and that step 19 uses to decide
# which scan pages are continuation pages. Defaults to gemini-3.5-flash
# because the empty exam is a vector PDF and native inline PDF input is more
# faithful than rasterizing. The helper auto-routes by model id: gemini* →
# native PDF (per-page slice); anything else → rasterized JPEG fallback.
EMPTY_EXAM_PAGE_CLASSIFICATION_MODEL=gemini-3.5-flash, 0, 256
EMPTY_EXAM_PAGE_CLASSIFICATION_WORKERS=16

# Step 13 — student_handwriting_check matcher.
# Per-scan-page vision call that, given step 12's catalog, MATCHES the page
# against one of the known empty-exam page types and one of the known
# empty-exam page numbers (plus an N+3 buffer for overflow). Also detects
# student handwriting in the same call. Drives steps 14 (cover-anchored
# name detection), 17 (heuristic page-order check), 18 (marking page
# register), and 21 (continuation pass uses the per-page page_type
# projected from step 12).
HANDWRITING_CHECK_MODEL=qwen3.6-flash, 0, 96
# JPEG render parameters for the per-scan-page vision call. Lower values
# trade vision-input fidelity for cheaper / faster API calls. Step 12
# (empty-exam classifier) keeps its own 150/75 fallback constants.
HANDWRITING_CHECK_JPEG_DPI=150
HANDWRITING_CHECK_JPEG_QUALITY=75
# Out-of-order recheck: when the primary call returns a page number that
# does not match the expected order, send the scan page AND the empty-exam
# page that should be in this position to a comparison model. If the model
# says the printed content matches, correct the page number; otherwise
# keep the originally detected one. Set HANDWRITING_CHECK_RECHECK_MODEL
# to empty to disable.
HANDWRITING_CHECK_RECHECK_MODEL=qwen3.6-flash, 0, 96
HANDWRITING_CHECK_RECHECK_JPEG_DPI=300
HANDWRITING_CHECK_RECHECK_JPEG_QUALITY=90
# Parallel workers for the per-scan-page vision check.
HANDWRITING_WORKERS=500

# Step 14 — student_names.
# Cover-anchored: prefers the AI-detected covers from step 13's
# ``handwriting.json`` to position OCR'ing the student-name field. Disagreement
# with the geometric cover positions is logged as a warning (likely misorder).
# Name OCR uses a non-streaming helper, so thinking_tokens MUST be 0.
NAME_DETECTION_MODEL=qwen3.6-flash, 0, 64
NAME_RECOGNITION_DPI=300
NAME_WORKERS=500
NAME_JPEG_QUALITY=95

# Step 15 — page_order_check.
# Pure heuristic over step 13's per-page detected_page_number — no LLM,
# no OCR, no per-step model. Compares each student's detected page-number
# sequence against the expected one (with cover_offset adjustment).
# 0 (default): print a loud warning and continue. 1: SystemExit(1).
PAGE_ORDER_CHECK_STRICT=0


# ── Phase 6 — Marking page register (pipeline step 16) ──────────────────────

# Step 16 — build_marking_register_v1
# Pure data transform — joins step 13 (handwriting.json) with step 14
# (page_assignments) and writes
# ``16_build_marking_register_v1/marking_page_register.json``. One primary
# call per non-cover scan page that has handwriting; continuation /
# figure / parent-stem extras are layered on by step 19
# (detect_cross_page_context). No env-var knobs.


# ── Empty-exam parse (pipeline steps 17–18) ──────────────────────────────────

# Step 17 — extract_exam_question_numbers
# One cheap call against the cut PDF returns number/type/page/subpage/marks
# (no text). Writes ``17_extract_exam_question_numbers/exam_scaffold.{ext}``.
EXTRACT_EXAM_QUESTION_NUMBERS_MODEL=gemini-3.5-flash, 2048, 8192

# Audit item [68]: post-process step 17 to override marks=0 → MCQ_DEFAULT_POINTS
# for any multiple_choice question. Cambridge papers usually print "[1]" next
# to MCQ stems but some past papers omit the bracket; the AI then extracts
# marks=0, which silently drops the question from the per-question total.
# Set to 0 to disable the override.
MCQ_DEFAULT_POINTS=1

# Step 18 — extract_exam_questions
# Per-page parallel calls populate text + options for each question on each
# page. Writes ``18_extract_exam_questions/exam_questions.{ext}`` + ``pages/``.
EXTRACT_EXAM_QUESTIONS_MODEL=gemini-3.5-flash, 2048, 32768
EXTRACT_EXAM_QUESTIONS_WORKERS=500


# ── Phase 8 — Cross-page context (pipeline step 19) ──────────────────────────

# Step 19 — detect_cross_page_context.
# true (default): when a child sub-question's page differs from its parent's
#   stem page, attach the parent page to the marking call so the marker
#   sees the question wording / printed flowchart.
# false: skip the parent-stem pass; figure cross-references still detected.
# Accepts 1/0, true/false, yes/no, on/off (case-insensitive).
CROSS_PAGE_PARENT_DETECTION=true


# ── Phase 9 — Mark scheme parsing (pipeline steps 20–24) ─────────────────────

# Step 20 — detect_mark_scheme_graphics
DETECT_SCHEME_GRAPHICS_MODEL=qwen3-vl-plus, 0, 8192
# DPI for cropping mark scheme graphics to PNG.
MARK_SCHEME_GRAPHICS_DPI=300
# Fractional margin added on all sides of detected bbox (0.0 = no margin).
SCHEME_GRAPHICS_MARGIN=0.01
# Parallel workers for the per-page graphics-detection vision call.
SCHEME_GRAPHICS_WORKERS=500

# Step 21 — assign_scheme_questions
# Which question numbers appear on each mark scheme page (cheap, fast vision
# call). Lets step 22 send only the relevant questions per page instead of
# the whole exam scaffold.
# Gemini → per-page PDF upload; Kimi → per-page PDF text-extract via
# Moonshot files API; everything else (qwen, grok) → base64 PNG. Same
# convention as step 22.
ASSIGN_SCHEME_QUESTIONS_MODEL=qwen3.6-flash, 512, 1024
# Parallel workers for the per-page question-assignment call.
ASSIGN_SCHEME_QUESTIONS_WORKERS=500

# Step 22 — parse_mark_scheme
# Correct answers + criteria (Gemini PDF / Kimi PDF-text / Qwen PNG, per-page parallel)
READ_MARK_SCHEME_MODEL=gemini-3.5-flash, 2048, 32768
# Parallel workers for the per-page mark-scheme parsing call (Gemini and OpenAI-compat paths).
PARSE_SCHEME_WORKERS=500

# Step 23 — transcribe_scheme_graphics
# Per-graphic vision call that converts each mark-scheme diagram into a short
# bulleted list of markable points (one bullet per scoreable element, in
# mark-scheme phrasing). Fed into step 27 ai_marking alongside the raw image
# so the marker has both modalities. Always runs; reuses prior transcriptions
# on resume.
TRANSCRIBE_SCHEME_GRAPHIC_MODEL=qwen3.6-plus, 0, 8192
TRANSCRIBE_SCHEME_GRAPHIC_WORKERS=500

# Step 24 — create_report:
# merges scaffold + mark scheme.


# ── Phase 10 — AI marking (pipeline steps 25–27) ─────────────────────────────

# Step 25 — ai_marking_blueprints:
# per-page templates from scaffold.

# Step 26 — extract_student_answers
# Transcribe-only pre-pass: vision model reads each (student, page) scan and
# fills student_answer per question, leaving marks/explanation for step 27.
# Same model class as MARKING_MODEL by default — the win is shorter outputs,
# not a cheaper model. Falls back to MARKING_MODEL when this var is unset.
EXTRACT_ANSWERS_MODEL=qwen3.6-plus, 4096, 32768

# Step 27 — ai_marking
# MARKING_DPI can be lower than PIPELINE_DEFAULT_DPI — 150 DPI is sufficient
# for handwriting and saves API upload time.
MARKING_MODEL=qwen3.6-plus, 4096, 64000
MARKING_DPI=300
MARKING_JPEG_QUALITY=95
# Per-page thinking-budget boost. When a page contains a question worth at
# least *_THRESHOLD marks, the marking thinking budget for that page's call
# is multiplied by *_MULTIPLIER. Set MULTIPLIER=1 to disable.
MARKING_THINKING_BOOST_THRESHOLD=10
MARKING_THINKING_BOOST_MULTIPLIER=2
# Parallel workers for AI marking and xelatex compilation. Also used by step 26
# (extract_student_answers) — same iter_marking_calls() loop, same worker pool.
MARKING_WORKERS=500
# Parallel workers for xelatex per-student PDF compilation (steps 28 + 30).
# Falls back to MARKING_WORKERS, then to 4 — declaring it here just makes the knob visible.
REPORT_COMPILE_WORKERS=500
# Rate-limit delays (seconds). Keep at 0.0; raise if the provider returns 429s.
GRADE_QUESTION_DELAY_S=0.0
PAGE_API_DELAY_S=0.0


# ── Phase 11 — Reports (pipeline steps 28–32) ────────────────────────────────

# Step 29 — grade-curve target. After computing the raw class average, every
# student's percentage is shifted by (target - class_avg), clamped to [0, 100].
# Override per run via the natural-language prompt: "curve at 70%". Default: 80.
GRADE_CURVE_TARGET=80

# Step 30 — show or hide the curved percentage in each per-student PDF header.
# When true the header reads "X% raw, Y% curved"; when false just "X%".
# Override per run via the prompt: "hide curve from students". Default: true.
# Class report PDF is unaffected (always shows the curved column).
CURVED_GRADE_VISIBLE=true

# Steps 32–33 — xelatex per-document timeout in seconds. Raise for very large
# reports or slow disks; lower for faster failure feedback during dev.
XELATEX_TIMEOUT=60

# Pipeline steps 33–34 (timing summary, AI costs) have no env-var knobs here.

# ─────────────────────────────────────────────────────────────────────────────
# eXam pipeline — on-screen practice with AI marking + pregenerated helpers.
# Text-only helpers and markers use Qwen for speed; the multimodal fallback for
# questions that contain a figure uses Gemini with the question PDF attached.
# ─────────────────────────────────────────────────────────────────────────────
EXAM_MARK_MODEL=qwen3.6-plus, 0, 8192
EXAM_PHYSICS_MARK_MODEL=qwen3.6-plus, 0, 4096
EXAM_HINT_MODEL=qwen3.6-flash, 0, 512
EXAM_SOLUTION_MODEL=qwen3.6-plus, 2048, 8192
EXAM_EXAMPLE_MODEL=qwen3.6-plus, 1024, 4096
EXAM_KB_MODEL=qwen3.6-plus, 1024, 4096
EXAM_PDF_MODEL=gemini-3.5-flash, 1024, 8192
