# Committed app defaults (non-secrets). Safe to version-control.
# Secrets stay in `.env` only (gitignored). See `.env.example`.

# Global default model — provider is inferred from the model name automatically:
#   gemini-*  →  GOOGLE_API_KEY
#   grok-*    →  XAI_API_KEY
#   qwen*     →  DASHSCOPE_API_KEY
AI_MODEL=gemini-2.5-flash

# Per-call-type model overrides (each falls back to AI_MODEL if unset):
# NL_MODEL=            # prompt interpretation
# MCQ_MODEL=           # AI explanation generation
# RANKING_MODEL=       # exercise ranking — future

# Login gate: true = no login modal; false = require access code (see ACCESS_CODE in comments below)
DISABLE_LOGIN=false

# Optional — uncomment here or set in process environment (not in .env):
# NL_SKIP_PRECHECK=1
# AI_PRECHECK_MODEL=
# ACCESS_CODE=NBFLS
# APP_SECRET_KEY=
# ASK_LOGIN=0
