# App defaults — safe to commit. Secrets (API keys) go in .env (gitignored).

# ── AI ────────────────────────────────────────────────────────────────────────
# Default model for all AI calls. Provider is inferred from the model name:
#
#   Google Gemini  (GOOGLE_API_KEY)
#     gemini-3.1-pro-preview      — best quality (preview)
#     gemini-3-flash-preview      — fast, frontier quality (preview)
#     gemini-3.1-flash-lite-preview — cheapest Gemini 3 (preview)
#     gemini-2.5-pro              — best stable quality
#     gemini-2.5-flash            — fast, good quality  ← AI_DEFAULT_MODEL
#     gemini-2.5-flash-lite       — cheapest / fastest stable
#
#   xAI Grok  (XAI_API_KEY)
#     grok-4                         — flagship
#     grok-4-1-fast-non-reasoning    — fast, low cost
#
#   Alibaba Qwen  (DASHSCOPE_API_KEY)
#     qwen3.6-plus       — balanced quality/speed, thinking mode
#     qwen3.5-plus       — fast, thinking mode
#     qwen3.5-flash      — cheapest / fastest, thinking mode
#     qwen3-max          — best quality, thinking mode
#
AI_DEFAULT_MODEL=gemini-2.5-flash

# Per-call overrides — each falls back to AI_DEFAULT_MODEL when unset:
# Skip the pre-validation before the main NL call entirely.
NL_SKIP_PRECHECK=false

# Model for the fast pre-validation step (use a cheap model).
AI_PRECHECK_MODEL=gemini-2.5-flash-lite

# Model for prompt interpretation.
# NL_MODEL=

# Model for MCQ explanation generation.
# MCQ_MODEL=

# Model for exercise ranking (not yet implemented).
# RANKING_MODEL=

# ── Login ─────────────────────────────────────────────────────────────────────
# true = open access; false = require the ACCESS_CODE below
DISABLE_LOGIN=false
ACCESS_CODE=NBFLS

# Optional: fix the session signing key so sessions survive server restarts.
# APP_SECRET_KEY=
